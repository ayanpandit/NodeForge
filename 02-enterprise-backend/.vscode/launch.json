{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Dev Server",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/src/server.js",
      "runtimeArgs": ["--watch"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Run Single Test File",
      "skipFiles": ["<node_internals>/**"],
      "program": "${file}",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--test"]
    }
  ]
}
